---
import "../styles/global.css";
import ContributionsApp from "../components/contributions-app";
import { fetchStars } from "../lib/stars";

const origin = Astro.url.origin;
const repoSlug = "leomosley/the-real-contributions-graph";
const repo = `https://github.com/${repoSlug}`;
const stars = await fetchStars(repoSlug);
const title = "The Real Contributions Graph";
const description =
  "See the GitHub contributions private orgs hide from your profile — the anonymous total recruiters and strangers can't normally see. Reveal any user's real graph and embed it in your README.";
const ogImage = `${origin}/og.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={origin} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#0a0a0b" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={origin} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="min-h-screen antialiased">
    <div class="grain" aria-hidden="true"></div>

    <header
      class="fixed left-0 right-0 top-0 z-50 flex items-center justify-between px-5 py-4 sm:px-8"
    >
      <img src="/favicon.svg" alt="" class="h-7 w-7 rounded-md opacity-90" />
      <a
        href={repo}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 rounded-full border border-white/[0.08] bg-white/[0.03] px-3.5 py-1.5 text-xs text-neutral-400 backdrop-blur-md transition-colors duration-200 hover:border-white/20 hover:text-neutral-200"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="h-3.5 w-3.5" aria-hidden="true">
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
        GitHub
        {
          stars !== null && stars > 0 && (
            <>
              <span class="h-3 w-px bg-white/10" />
              <span class="flex items-center gap-1 text-neutral-500">
                <svg
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="h-3 w-3 text-yellow-500/70"
                  aria-hidden="true"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
                {stars.toLocaleString()}
              </span>
            </>
          )
        }
      </a>
    </header>

    <main
      class="mx-auto flex min-h-screen max-w-4xl flex-col items-center px-5 pb-20 pt-28 sm:pt-36"
    >
      <h1
        class="fade-up delay-1 text-center text-3xl font-light leading-tight tracking-tight text-white sm:text-5xl"
      >
        See the work GitHub <span class="text-accent">hides</span>.
      </h1>
      <p
        class="fade-up delay-2 mt-5 max-w-md text-center text-sm leading-relaxed text-neutral-500 sm:text-base"
      >
        GitHub drops your private-org contributions from your profile, but they still count.

        <div class="fade-up delay-3 mt-10 w-full">
          <ContributionsApp client:load />
        </div>
      </p>
    </main>
  </body>
</html>
