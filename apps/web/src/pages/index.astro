---
import "../styles/global.css";
import ContributionsApp from "../components/contributions-app";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>The Real Contributions Graph</title>
  </head>
  <body style="background:#0d1117; min-height:100vh; margin:0; padding:48px 24px;">
    <main style="max-width:900px; margin:0 auto;">
      <h1 style="color:#e6edf3; font-family:system-ui,sans-serif; margin:0 0 4px;">
        The Real Contributions Graph
      </h1>
      <p style="color:#8b949e; font-family:system-ui,sans-serif; margin:0 0 32px;">
        The anonymous view — the count recruiters and strangers can't normally see.
      </p>
      <ContributionsApp client:load />
    </main>
  </body>
</html>
